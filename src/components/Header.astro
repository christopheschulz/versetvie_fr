---
import { getDownloadPath, getLangFromUrl, useTranslations, getLocalePrefix } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = getLocalePrefix(lang);
const home = prefix ? `${prefix}/` : '/';
const downloadPath = getDownloadPath(lang);
---

<header class="fixed left-0 right-0 top-0 z-50 px-3 pt-3 sm:px-5">
  <div class="nav-shell glass mx-auto max-w-7xl rounded-2xl border border-[var(--color-border)]/70 px-3 sm:px-4">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href={home} class="group flex items-center gap-3">
        <img src="/icon.png" alt="Verset Vie" class="h-9 w-9 rounded-[11px] shadow-sm transition-transform group-hover:-rotate-3 group-hover:scale-105" />
        <span class="hidden font-serif text-xl font-semibold tracking-[-.03em] sm:block">Verset Vie</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        <a href={home} data-section="hero" class="nav-link">
          {t('nav.home')}
        </a>
        <a href={`${prefix}/#screenshots`} data-section="screenshots" class="nav-link">
          {t('nav.screenshots')}
        </a>
        <a href={`${prefix}/#features`} data-section="features" class="nav-link">
          {t('nav.features')}
        </a>
        <a href={`${prefix}/#testimonials`} data-section="testimonials" class="nav-link">
          {t('nav.testimonials')}
        </a>
        <a href={`${prefix}/#pricing`} data-section="pricing" class="nav-link">
          {t('nav.support')}
        </a>
        <a href={`${prefix}/#faq`} data-section="faq" class="nav-link">
          {t('nav.faq')}
        </a>
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-2 sm:gap-3">
        <LanguageSwitcher />

        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          class="cursor-pointer rounded-full p-2.5 transition-colors hover:bg-[var(--color-primary-bg)]"
          aria-label="Toggle theme"
        >
          <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/>
          </svg>
          <svg class="w-5 h-5 dark:hidden" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
          </svg>
        </button>

        <a
          href={downloadPath}
          data-section="download"
          class="hidden min-h-11 items-center justify-center rounded-full bg-[var(--color-primary)] px-5 text-sm font-bold text-white shadow-[0_8px_25px_rgba(98,100,232,.22)] transition hover:-translate-y-0.5 sm:inline-flex"
        >
          {t('nav.download')}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="rounded-full p-2.5 transition-colors hover:bg-[var(--color-primary-bg)] lg:hidden"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="mx-auto mt-2 hidden max-w-7xl overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[var(--shadow-float)] lg:hidden">
    <div class="space-y-1 p-3">
      <a href={home} data-section="hero" class="nav-link nav-link--mobile">
        {t('nav.home')}
      </a>
      <a href={`${prefix}/#screenshots`} data-section="screenshots" class="nav-link nav-link--mobile">
        {t('nav.screenshots')}
      </a>
      <a href={`${prefix}/#features`} data-section="features" class="nav-link nav-link--mobile">
        {t('nav.features')}
      </a>
      <a href={`${prefix}/#testimonials`} data-section="testimonials" class="nav-link nav-link--mobile">
        {t('nav.testimonials')}
      </a>
      <a href={`${prefix}/#pricing`} data-section="pricing" class="nav-link nav-link--mobile">
        {t('nav.support')}
      </a>
      <a href={`${prefix}/#faq`} data-section="faq" class="nav-link nav-link--mobile">
        {t('nav.faq')}
      </a>
      <a href={downloadPath} data-section="download" class="nav-link nav-link--mobile">
        {t('nav.download')}
      </a>
      <a href={lang === 'de' ? `${prefix}/kontakt` : `${prefix}/contact`} data-section="contact" class="nav-link nav-link--mobile">
        {t('nav.contact')}
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-shell {
    box-shadow: 0 12px 40px rgba(38, 45, 83, .08);
  }

  .nav-link {
    position: relative;
    padding: 0.55rem 0.72rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-weight: 600;
    transition: color 0.2s ease, background 0.2s ease;
    border-radius: 999px;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .nav-link::after {
    position: absolute;
    bottom: .32rem;
    left: 50%;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    content: '';
    opacity: 0;
    transform: translateX(-50%) translateY(3px);
    transition: opacity .2s ease, transform .2s ease;
  }

  .nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
    background: transparent;
  }

  .nav-link.active::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .nav-link--mobile {
    display: block;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
  }

  .nav-link--mobile::after {
    display: none;
  }

  .nav-link--mobile.active {
    background: var(--color-primary);
    color: white;
    font-weight: 600;
  }

  .nav-link--mobile:hover:not(.active) {
    background: var(--color-surface);
  }
</style>

<script>
  function initNavigation() {
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (mobileMenuBtn && mobileMenu) {
      const btn = mobileMenuBtn as HTMLButtonElement;
      const menu = mobileMenu as HTMLElement;
      let trapHandler: ((e: KeyboardEvent) => void) | null = null;

      function openMenu() {
        menu.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        const focusable = menu.querySelectorAll<HTMLElement>('a, button');
        focusable[0]?.focus();

        trapHandler = (e: KeyboardEvent) => {
          if (e.key === 'Escape') { closeMenu(); return; }
          if (e.key !== 'Tab') return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey) {
            if (document.activeElement === first) { e.preventDefault(); last?.focus(); }
          } else {
            if (document.activeElement === last) { e.preventDefault(); first?.focus(); }
          }
        };
        document.addEventListener('keydown', trapHandler);
      }

      function closeMenu() {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (trapHandler) { document.removeEventListener('keydown', trapHandler); trapHandler = null; }
        btn.focus();
      }

      btn.addEventListener('click', () => {
        if (menu.classList.contains('hidden')) openMenu(); else closeMenu();
      });
    }

    // Active section detection
    const sections = ['hero', 'screenshots', 'features', 'testimonials', 'pricing', 'faq', 'download'];
    const navLinks = document.querySelectorAll('.nav-link');

    function setActiveLink(sectionId: string) {
      navLinks.forEach(link => {
        const linkSection = link.getAttribute('data-section');
        link.classList.toggle('active', linkSection === sectionId);
      });
    }

    // Handle click on nav links - activate immediately
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        const sectionId = link.getAttribute('data-section');
        if (sectionId) {
          setActiveLink(sectionId);
        }
        if (mobileMenu) {
          mobileMenu.classList.add('hidden');
        }
      });
    });

    // Detect current page from pathname to set the correct active link
    const pathSegments = window.location.pathname.split('/').filter(Boolean);
    const lastSegment = pathSegments[pathSegments.length - 1] || '';
    const homepageSegments = ['', 'fr', 'en', 'de'];
    const contactSegments = ['contact', 'kontakt'];
    const downloadSegments = ['telecharger', 'download', 'herunterladen'];

    if (contactSegments.includes(lastSegment)) {
      setActiveLink('contact');
      return; // no scroll detection on contact page
    }

    if (downloadSegments.includes(lastSegment)) {
      setActiveLink('download');
      return; // no scroll detection on download page
    }

    if (!homepageSegments.includes(lastSegment)) {
      // Legal pages and other sub-pages: no active nav item
      return;
    }

    // Homepage: detect active section via hash then IntersectionObserver
    const hash = window.location.hash.replace('#', '');
    if (hash && sections.includes(hash)) {
      setActiveLink(hash);
    } else {
      setActiveLink('hero');
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const sectionId = entry.target.id;
          if (sectionId) {
            setActiveLink(sectionId);
          }
        }
      });
    }, {
      root: null,
      rootMargin: '-20% 0px -60% 0px',
      threshold: 0
    });

    sections.forEach(sectionId => {
      const element = document.getElementById(sectionId);
      if (element) {
        observer.observe(element);
      }
    });
  }

  // Run on initial load and page transitions
  document.addEventListener('astro:page-load', initNavigation);
  document.addEventListener('DOMContentLoaded', initNavigation);
</script>
