---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const testimonials = [
  {
    name: 'Manon',
    text: t('testimonials.manon.text'),
    rating: 5,
    featured: true,
  },
  {
    name: 'Jérémie',
    text: t('testimonials.jeremie.text'),
    rating: 5,
  },
  {
    name: 'Nadia',
    text: t('testimonials.nadia.text'),
    rating: 5,
  },
];
---

<section id="testimonials" class="relative overflow-hidden bg-[var(--color-warm-bg)]/70 px-4 py-24 sm:py-32">
  <div class="testimonial-mark" aria-hidden="true">“</div>
  <div class="relative mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-[0.72fr_1.28fr] lg:items-center">
      <div>
        <p class="eyebrow">{t('testimonials.eyebrow')}</p>
        <h2 class="section-title mt-5 text-[var(--color-text)]">{t('testimonials.title')}</h2>
        <p class="mt-4 text-sm italic text-[var(--color-text-tertiary)]">
          {lang === 'fr' ? t('testimonials.storeNote') : t('testimonials.translationNote')}
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {testimonials.map((testimonial) => (
          <article class={`testimonial-card ${testimonial.featured ? 'md:row-span-2' : ''}`}>
            <div class="mb-5 flex gap-1" aria-label={`${testimonial.rating} étoiles`} role="img">
              {[...Array(testimonial.rating)].map(() => (
                <svg class="h-4 w-4 text-[var(--color-premium)]" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <blockquote class={`${testimonial.featured ? 'text-lg' : 'text-sm'} leading-relaxed text-[var(--color-text-secondary)]`}>
              "{testimonial.text}"
            </blockquote>

            <div class="mt-6 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-primary)] text-sm font-semibold text-white">
                {testimonial.name.charAt(0)}
              </div>
              <span class="font-medium">{testimonial.name}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    border: 1px solid var(--color-border);
    border-radius: 1.75rem;
    background: color-mix(in srgb, var(--color-card) 88%, transparent);
    padding: 1.65rem;
    box-shadow: var(--shadow-float);
    backdrop-filter: blur(12px);
    transition: transform .25s ease;
  }

  .testimonial-card:hover { transform: translateY(-4px) rotate(-.25deg); }

  .testimonial-card:first-child {
    background: var(--color-text);
    color: var(--color-background);
  }

  .testimonial-card:first-child blockquote { color: color-mix(in srgb, var(--color-background) 78%, transparent); }

  .testimonial-mark {
    position: absolute;
    top: -5rem;
    right: 4vw;
    color: color-mix(in srgb, var(--color-primary) 9%, transparent);
    font-family: var(--font-serif);
    font-size: 28rem;
    line-height: 1;
    pointer-events: none;
  }
</style>
