---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const freeFeatures = [
  t('pricing.free.feature1'),
  t('pricing.free.feature2'),
  t('pricing.free.feature3'),
  t('pricing.free.feature4'),
];

const premiumFeatures = [
  t('pricing.support.feature1'),
  t('pricing.support.feature2'),
  t('pricing.support.feature3'),
  t('pricing.support.feature4'),
  t('pricing.support.feature5'),
  t('pricing.support.feature6'),
  t('pricing.support.feature7'),
];
---

<section id="pricing" class="px-4 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto mb-14 max-w-3xl text-center">
      <p class="eyebrow justify-center">{t('pricing.eyebrow')}</p>
      <h2 class="section-title mt-5 text-[var(--color-text)]">{t('pricing.title')}</h2>
      <p class="mt-4 text-lg leading-relaxed text-[var(--color-text-secondary)]">{t('pricing.description')}</p>
    </div>

    <div class="grid gap-5 lg:grid-cols-[0.88fr_1.12fr]">
      <article class="rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-card)] p-6 shadow-[var(--shadow-float)] sm:p-9">
        <div class="mb-6">
          <h3 class="text-2xl font-semibold">{t('pricing.free.title')}</h3>
        </div>

        <ul class="space-y-4">
          {freeFeatures.map((feature) => (
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-secondary)]">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5" />
              </svg>
              <span>{feature}</span>
            </li>
          ))}
        </ul>
      </article>

      <article class="premium-card relative overflow-hidden rounded-[2rem] border border-[var(--color-primary)]/35 bg-[var(--color-card)] p-6 shadow-[var(--shadow-soft)] sm:p-9">
        <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-[var(--color-primary)] via-[var(--color-accent)] to-[var(--color-primary)]"></div>
        <div class="mb-6">
          <div>
            <h3 class="text-2xl font-semibold">{t('pricing.support.subtitle')}</h3>
            <p class="mt-2 text-sm text-[var(--color-text-secondary)]">{t('pricing.premium.note')}</p>
          </div>
        </div>

        <ul class="grid gap-4 sm:grid-cols-2">
          {premiumFeatures.map((feature) => (
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-secondary)]">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--color-premium)]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span>{feature}</span>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .premium-card::after {
    position: absolute;
    right: -6rem;
    bottom: -8rem;
    width: 18rem;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(98,100,232,.15), transparent 68%);
    content: '';
    pointer-events: none;
  }
</style>
